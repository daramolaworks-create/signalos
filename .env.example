DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat

TELEGRAM_BOT_TOKEN=

# X OAuth 1.0a user-context credentials. Required only when approving/publishing.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

DEFAULT_USER_ID=
ADMIN_PASSWORD=
PORT=3000

# Optional: automatically generate drafts each day. Posts still require Telegram approval.
DAILY_GENERATOR_ENABLED=false
DAILY_GENERATOR_CRON=0 9 * * *
DAILY_GENERATOR_TIMEZONE=Europe/London
DAILY_GENERATOR_TOPIC=evergreen systems, incentives, and technology
DAILY_GENERATOR_POST_COUNT=10
